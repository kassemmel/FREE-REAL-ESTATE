# Copy to .env and fill in. Do NOT commit .env (it holds live secrets).
# Each model route below is optional — leave a section blank to hide it in the UI.

# --- Prisma AIRS (prompt/response scanning for the Ollama + Azure routes) ---
PRISMA_AIRS_API_KEY=
PRISMA_AIRS_PROFILE=
# Region endpoint: service / service-de / service-in / service-sg
PRISMA_AIRS_URL=https://service-de.api.aisecurity.paloaltonetworks.com

# --- Azure AI Foundry / Azure OpenAI ---
# Endpoint: the v1 (OpenAI-compatible) URL works as-is; a classic resource URL
#   (https://<res>.openai.azure.com, no path) also works via the api-version param.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
# Comma-separated deployment names; each appears in the UI as "azure/<name>"
AZURE_OPENAI_DEPLOYMENTS=

# --- Portkey AI gateway (route traffic through the gateway instead of direct) ---
# Hosted gateway, or set to your self-hosted gateway root (must end in /v1).
PORTKEY_BASE_URL=https://api.portkey.ai/v1
PORTKEY_API_KEY=
# Provider routing + guardrails can come from a config attached to the API key
# in Portkey (recommended) — then leave the three below blank. Otherwise pick ONE:
#   a virtual key, a saved config id, or a provider slug.
PORTKEY_VIRTUAL_KEY=
PORTKEY_CONFIG=
PORTKEY_PROVIDER=
# Comma-separated model names; each appears in the UI as "portkey/<name>".
PORTKEY_MODELS=
